RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxx
# LIVE PayU merchant key + salt (PayU Dashboard → production)
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
PAYU_ENV=production
API_PUBLIC_URL=http://localhost:4000
RESEND_API_KEY=
