PORT=4000
CLIENT_URL=http://localhost:5173
# MongoDB Atlas connection string (required in production)
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/esoftwarestore
JWT_SECRET=replace-with-a-long-random-secret
